# =============================================================================
# Configurazione backend Divide et Quantifica
# Copia questo file in ".env" e compila i valori (soprattutto quelli Supabase).
# =============================================================================

# Porta del server HTTP
PORT=3000

# Origine consentita per il CORS (il frontend Angular in sviluppo)
CORS_ORIGIN=http://localhost:8100

# --- Supabase (Postgres) ---
# Dashboard Supabase -> Project Settings -> Database -> Connection string (URI).
# Usa la stringa "Connection pooling" (porta 6543) per il deploy serverless,
# oppure "Direct connection" (porta 5432) in locale. Deve includere ?sslmode=require
DATABASE_URL=postgresql://postgres:LA_TUA_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres?sslmode=require

# --- Autenticazione ---
# Segreto per firmare i JWT (metti una stringa lunga e casuale)
JWT_SECRET=cambia-questo-con-una-stringa-lunga-e-casuale
# Durata del token
JWT_EXPIRES_IN=7d

# --- Regole applicative ---
# Costo in euro della licenza Premium (scalato dal credito; include l'accessorio fidelity)
PREMIUM_PRICE=10
# Minuti di validita' della cache dei prezzi Yahoo Finance
QUOTE_CACHE_MINUTES=20

# --- Email (Gmail SMTP via nodemailer) ---
# Account Gmail e App Password (16 caratteri, generata da account Google).
# Senza credenziali le email vengono solo loggate.
MAIL_USER=
MAIL_PASS=
# Mittente mostrato nelle email (di norma lo stesso account Gmail)
MAIL_FROM=Divide et Quantifica <tuo@gmail.com>
# URL del frontend per i link nelle email di recupero password
FRONTEND_URL=http://localhost:8100
